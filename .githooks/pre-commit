#!/usr/bin/env bash
# Keep skills/natural-japanese/ (plugin distribution copy) in sync with the
# root SKILL.md / references/ / scripts/ / assets/ (single source of truth).
#
# Enable with: git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

"${REPO_ROOT}/scripts/sync-skill.sh"

git -C "${REPO_ROOT}" add skills/natural-japanese

# Run the fixture regression check only when it's relevant (uv startup makes
# running it on every commit noticeably slow), i.e. when the linter itself
# (lint.py) or its shared foundation (textcore.py) or the fixtures were
# touched in this commit.
if git -C "${REPO_ROOT}" diff --cached --name-only | grep -qE '^scripts/lint\.py$|^scripts/textcore\.py$|^scripts/fixtures/'; then
  "${REPO_ROOT}/scripts/check-fixtures.sh"
fi
